---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gestionar Portafolio - Anais Content">
  <main class="min-h-screen bg-[#F5EFEB] pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-12">
        <a href="/admin/dashboard" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-[#567C8D] hover:text-[#1C2B3A] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1 class="font-display text-3xl font-bold text-[#1C2B3A] hidden md:block">Gestión de Proyectos</h1>
        <button id="add-project-btn" class="bg-[#1C2B3A] text-white px-8 py-4 rounded-2xl font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-[#567C8D] transition-all shadow-xl active:scale-95">
          + Nuevo Proyecto
        </button>
      </div>

      <div id="loading-spinner" class="py-20 flex flex-col items-center gap-4">
        <div class="w-12 h-12 border-4 border-[#567C8D] border-t-transparent rounded-full animate-spin"></div>
        <span class="text-[10px] font-black uppercase tracking-widest text-[#567C8D]/60">Cargando portafolio...</span>
      </div>

      <div class="grid gap-6 opacity-0 transition-opacity duration-1000" id="projects-list">
         <!-- Data injected via JS -->
      </div>
    </div>

    <!-- Project Modal -->
    <div id="project-modal" class="fixed inset-0 bg-[#1C2B3A]/80 backdrop-blur-sm z-50 hidden items-center justify-center p-6">
        <div class="bg-white rounded-[40px] max-w-2xl w-full p-10 shadow-2xl overflow-y-auto max-h-[90vh]">
            <div class="flex justify-between items-center mb-8">
                <h2 id="modal-title" class="font-display text-3xl font-bold text-[#1C2B3A]">Nuevo Proyecto</h2>
                <button id="close-modal" class="text-[#567C8D] hover:text-[#1C2B3A]">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <form id="project-form" class="space-y-6">
                <input type="hidden" id="project-id" name="id" />
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Título</label>
                        <input type="text" id="field-title" name="title" required class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Categoría</label>
                        <input type="text" id="field-category" name="category" placeholder="Ej: Luxury" class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Ubicación</label>
                    <input type="text" id="field-location" name="location" placeholder="Ej: San José, CR" class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Galería (Máximo 5 imágenes - La primera será la portada)</label>
                    <div class="grid grid-cols-5 gap-4 mb-4" id="portfolio-gallery-preview">
                        <!-- Image slots -->
                    </div>
                    <div class="flex items-center gap-4">
                        <input type="file" id="field-gallery-upload" accept="image/*" multiple class="hidden" />
                        <label for="field-gallery-upload" class="flex-grow bg-[#F5EFEB] text-[#1C2B3A] px-6 py-3 rounded-xl font-bold text-[10px] uppercase tracking-widest cursor-pointer hover:bg-[#1C2B3A] hover:text-white transition-all text-center">
                            Añadir Imágenes
                        </label>
                    </div>
                    <input type="hidden" id="field-image-url" name="image_url" />
                    <input type="hidden" id="field-gallery-json" name="gallery" />
                    <p class="text-[9px] text-[#567C8D] mt-3 italic">Recomendado: 1200x800px. Arrastra para reordenar (próximamente) o elimina para cambiar el orden.</p>
                </div>

                <div class="flex items-center gap-3">
                    <input type="checkbox" id="field-wide" name="is_wide" class="w-5 h-5 rounded border-[#567C8D] text-[#1C2B3A] focus:ring-[#1C2B3A]" />
                    <label for="field-wide" class="text-[11px] font-bold text-[#567C8D] uppercase tracking-widest">¿Mostrar en ancho completo?</label>
                </div>

                <div class="pt-6 border-t border-[#F5EFEB] flex flex-col md:flex-row gap-4">
                    <button type="submit" id="save-project-btn" class="flex-grow bg-[#1C2B3A] text-white py-5 rounded-2xl font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-[#567C8D] transition-all shadow-xl disabled:opacity-50">
                        Guardar Proyecto
                    </button>
                    <button type="button" id="delete-confirm-btn" class="hidden bg-red-50 text-red-500 px-8 py-5 rounded-2xl font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-red-500 hover:text-white transition-all">
                        Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';
  import { getProjects, safeEncode, safeDecode } from '../../utils/data';

  const checkAuth = () => {
    if (sessionStorage.getItem('admin_access') !== 'true') {
      window.location.href = '/admin';
      return false;
    }
    return true;
  };

  if (checkAuth()) {
    const listContainer = document.getElementById('projects-list');
    const spinner = document.getElementById('loading-spinner');
    const modal = document.getElementById('project-modal');
    const projectForm = document.getElementById('project-form') as HTMLFormElement;
    const addBtn = document.getElementById('add-project-btn');
    const closeBtn = document.getElementById('close-modal');
    const galleryUpload = document.getElementById('field-gallery-upload') as HTMLInputElement;
    const galleryPreview = document.getElementById('portfolio-gallery-preview');
    const imageUrlInput = document.getElementById('field-image-url') as HTMLInputElement;
    const galleryJsonInput = document.getElementById('field-gallery-json') as HTMLInputElement;
    const deleteBtn = document.getElementById('delete-confirm-btn');

    let currentGallery: string[] = [];

    async function loadProjects() {
        try {
            if (spinner) spinner.classList.remove('hidden');
            if (listContainer) listContainer.classList.add('opacity-0');
            
            const projects = await getProjects();
            if (!listContainer) return;

            listContainer.innerHTML = projects.map(p => `
                <div class="bg-white p-6 md:p-8 rounded-[32px] shadow-lg flex flex-col md:flex-row items-center gap-6 md:gap-8 group border border-transparent hover:border-[#567C8D]/20 transition-all">
                    <div class="w-24 h-24 md:w-32 md:h-32 aspect-square rounded-2xl overflow-hidden bg-[#F5EFEB] shrink-0">
                        <img src="${p.image}" alt="${p.title}" class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-grow text-center md:text-left">
                        <h3 class="text-xl font-bold text-[#1C2B3A] mb-1">${p.title}</h3>
                        <p class="text-[10px] text-[#567C8D] uppercase tracking-widest font-black opacity-70">${p.category || 'Portfolio'} • ${p.location}</p>
                    </div>
                    <div class="flex gap-4">
                        <button class="edit-btn p-4 rounded-xl bg-[#F5EFEB] text-[#1C2B3A] hover:bg-[#1C2B3A] hover:text-white transition-all active:scale-90" 
                                data-project="${safeEncode(p)}" title="Editar">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </button>
                    </div>
                </div>
            `).join('');

            if (projects.length === 0) {
                listContainer.innerHTML = '<p class="text-center py-20 text-[#567C8D] font-bold uppercase tracking-widest text-xs">No hay proyectos para mostrar.</p>';
            }

            listContainer.classList.remove('opacity-0');
            if (spinner) spinner.classList.add('hidden');

            // Attach edit events
            document.querySelectorAll('.edit-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const encodedData = (btn as HTMLButtonElement).dataset.project || '';
                    const data = safeDecode(encodedData) as any;
                    openModal(data);
                });
            });
        } catch (e) {
            console.error("Error loading portfolio", e);
        }
    }

    function updateGalleryUI() {
        if (!galleryPreview) return;
        
        galleryPreview.innerHTML = currentGallery.map((url, idx) => `
            <div class="relative aspect-square rounded-xl overflow-hidden group border border-[#567C8D]/10">
                <img src="${url}" class="w-full h-full object-cover" />
                <button type="button" class="remove-gallery-img absolute inset-0 bg-red-500/80 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity font-bold text-[8px] uppercase" data-index="${idx}">
                    Eliminar
                </button>
                ${idx === 0 ? '<div class="absolute top-2 left-2 bg-green-500 text-white text-[6px] font-black uppercase px-2 py-1 rounded-full shadow-lg">Portada</div>' : ''}
            </div>
        `).join('');

        // Placeholder for remaining empty slots (up to 5)
        for (let i = currentGallery.length; i < 5; i++) {
            galleryPreview.innerHTML += `
               <div class="aspect-square rounded-xl bg-[#F5EFEB] border-2 border-dashed border-[#567C8D]/10 flex items-center justify-center text-[#567C8D]/20 text-xs">
                 ${i + 1}
               </div>
            `;
        }

        imageUrlInput.value = currentGallery[0] || '';
        galleryJsonInput.value = JSON.stringify(currentGallery);

        document.querySelectorAll('.remove-gallery-img').forEach(btn => {
            btn.addEventListener('click', () => {
                const index = parseInt((btn as HTMLButtonElement).dataset.index!);
                currentGallery.splice(index, 1);
                updateGalleryUI();
            });
        });
    }

    function openModal(project = null) {
        projectForm.reset();
        currentGallery = [];
        
        if (project) {
            document.getElementById('modal-title')!.innerText = 'Editar Proyecto';
            (document.getElementById('project-id') as HTMLInputElement).value = project.id;
            (document.getElementById('field-title') as HTMLInputElement).value = project.title;
            (document.getElementById('field-category') as HTMLInputElement).value = project.category || '';
            (document.getElementById('field-location') as HTMLInputElement).value = project.location || '';
            (document.getElementById('field-wide') as HTMLInputElement).checked = project.wide;
            
            // Map the gallery properly (handle cases where only single image existed)
            if (project.gallery && Array.isArray(project.gallery) && project.gallery.length > 0) {
               currentGallery = [...project.gallery];
            } else if (project.image) {
               currentGallery = [project.image];
            }
            
            updateGalleryUI();
            if (deleteBtn) deleteBtn.classList.remove('hidden');
        } else {
            document.getElementById('modal-title')!.innerText = 'Nuevo Proyecto';
            (document.getElementById('project-id') as HTMLInputElement).value = '';
            updateGalleryUI();
            if (deleteBtn) deleteBtn.classList.add('hidden');
        }

        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
    }

    function closeModal() {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
    }

    addBtn?.addEventListener('click', () => openModal());
    closeBtn?.addEventListener('click', closeModal);

    galleryUpload?.addEventListener('change', async () => {
        const files = galleryUpload.files;
        if (!files || files.length === 0) return;

        if (currentGallery.length + files.length > 5) {
            alert("Máximo 5 imágenes por proyecto");
            return;
        }

        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const fileExt = file.name.split('.').pop();
            const fileName = `prop-${Date.now()}-${i}.${fileExt}`;
            const filePath = `portfolio/${fileName}`;

            try {
                const { error } = await supabase.storage.from('assets').upload(filePath, file);
                if (error) throw error;

                const { data: { publicUrl } } = supabase.storage.from('assets').getPublicUrl(filePath);
                currentGallery.push(publicUrl);
                updateGalleryUI();
            } catch (err: any) {
                alert("Error al subir imagen: " + err.message);
            }
        }
    });

    projectForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const saveBtn = document.getElementById('save-project-btn') as HTMLButtonElement;
        saveBtn.disabled = true;

        if (currentGallery.length === 0) {
            alert("Debes subir al menos una imagen");
            saveBtn.disabled = false;
            return;
        }

        const formData = new FormData(projectForm);
        const payload = {
            title: formData.get('title'),
            category: formData.get('category'),
            location: formData.get('location'),
            image_url: currentGallery[0],
            gallery: currentGallery,
            is_wide: formData.get('is_wide') === 'on'
        };

        const id = formData.get('id');

        try {
            let error;
            if (id) {
                const { error: err } = await supabase.from('portfolio').update(payload).eq('id', id);
                error = err;
            } else {
                const { error: err } = await supabase.from('portfolio').insert([payload]);
                error = err;
            }

            if (error) throw error;
            
            closeModal();
            loadProjects();
        } catch (err: any) {
            alert("Error al guardar: " + err.message);
        } finally {
            saveBtn.disabled = false;
        }
    });

    deleteBtn?.addEventListener('click', async () => {
        if (!confirm('¿Estás seguro de que deseas eliminar este proyecto?')) return;
        
        const id = (document.getElementById('project-id') as HTMLInputElement).value;
        if (!id) return;

        try {
            const { error } = await supabase.from('portfolio').delete().eq('id', id);
            if (error) throw error;
            closeModal();
            loadProjects();
        } catch (err: any) {
            alert("Error al eliminar: " + err.message);
        }
    });

    loadProjects();
  }
</script>
