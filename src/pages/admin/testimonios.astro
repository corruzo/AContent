---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gestionar Testimonios - Anais Content">
  <main class="min-h-screen bg-[#F5EFEB] pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-12">
        <a href="/admin/dashboard" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-[#567C8D] hover:text-[#1C2B3A] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1 class="font-display text-3xl font-bold text-[#1C2B3A] hidden md:block">Testimonios & Reseñas</h1>
        <button id="add-testimonial-btn" class="bg-[#1C2B3A] text-white px-8 py-4 rounded-2xl font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-[#567C8D] transition-all shadow-xl active:scale-95">
          + Nuevo Testimonio
        </button>
      </div>

      <div id="loading-spinner" class="py-20 flex flex-col items-center gap-4">
        <div class="w-12 h-12 border-4 border-[#567C8D] border-t-transparent rounded-full animate-spin"></div>
        <span class="text-[10px] font-black uppercase tracking-widest text-[#567C8D]/60">Cargando testimonios...</span>
      </div>

      <div class="grid gap-6 opacity-0 transition-opacity duration-1000" id="testimonials-list"></div>
    </div>

    <!-- Modal -->
    <div id="testimonial-modal" class="fixed inset-0 bg-[#1C2B3A]/80 backdrop-blur-sm z-50 hidden items-center justify-center p-6">
        <div class="bg-white rounded-[40px] max-w-lg w-full p-10 shadow-2xl overflow-y-auto max-h-[90vh]">
            <div class="flex justify-between items-center mb-8">
                <h2 id="modal-title" class="font-display text-2xl font-bold text-[#1C2B3A]">Nuevo Testimonio</h2>
                <button id="close-modal" class="text-[#567C8D] hover:text-[#1C2B3A]">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <form id="testimonial-form" class="space-y-6">
                <input type="hidden" id="testimonial-id" name="id" />

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Texto del Testimonio</label>
                    <!-- name="content" coincide con la columna DB -->
                    <textarea id="field-text" name="content" required rows="4"
                        class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]"></textarea>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Autor</label>
                        <!-- name="name" coincide con la columna DB -->
                        <input type="text" id="field-author" name="name" required
                            class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Iniciales (Avatar)</label>
                        <!-- name="image_url" coincide con la columna DB — almacena las iniciales como texto -->
                        <input type="text" id="field-avatar" name="image_url" maxlength="2" placeholder="Ej: RA"
                            class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-[#567C8D] mb-3">Rol / Empresa</label>
                    <input type="text" id="field-role" name="role" required placeholder="Ej: Director Comercial"
                        class="w-full bg-[#F5EFEB] border-none rounded-2xl px-6 py-4 text-[#1C2B3A]" />
                </div>

                <div class="pt-6 border-t border-[#F5EFEB] flex flex-col gap-4">
                    <button type="submit" id="save-testimonial-btn"
                        class="bg-[#1C2B3A] text-white py-5 rounded-2xl font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-[#567C8D] transition-all shadow-xl disabled:opacity-50">
                        Guardar Testimonio
                    </button>
                    <button type="button" id="delete-confirm-btn"
                        class="hidden bg-red-50 text-red-500 py-4 rounded-2xl font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-red-500 hover:text-white transition-all border border-red-100">
                        Eliminar Testimonio
                    </button>
                </div>
            </form>
        </div>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';
  import { getTestimonials, safeEncode, safeDecode } from '../../utils/data';

  if (sessionStorage.getItem('admin_access') !== 'true') {
    window.location.href = '/admin';
  } else {

    const listContainer  = document.getElementById('testimonials-list');
    const spinner        = document.getElementById('loading-spinner');
    const modal          = document.getElementById('testimonial-modal');
    const testimonialForm = document.getElementById('testimonial-form') as HTMLFormElement;
    const addBtn         = document.getElementById('add-testimonial-btn');
    const closeBtn       = document.getElementById('close-modal');
    const deleteBtn      = document.getElementById('delete-confirm-btn');

    // ── unicode-safe encode/decode ─────────────────────────────────────────
    // (Consumido desde utils para consistencia)


    async function loadTestimonials() {
        try {
            if (spinner)        spinner.classList.remove('hidden');
            if (listContainer)  listContainer.classList.add('opacity-0');

            // getTestimonials() ya mapea content→text, name→author, image_url→avatar
            const testimonials = await getTestimonials();
            if (!listContainer) return;

            listContainer.innerHTML = testimonials.length === 0
                ? '<div class="py-20 text-center"><p class="text-[#567C8D] font-bold uppercase tracking-widest text-xs">Aún no hay testimonios cargados.</p></div>'
                : testimonials.map(t => `
                    <div class="bg-white p-8 rounded-[32px] shadow-lg flex flex-col gap-6 group hover:shadow-2xl transition-all border border-transparent hover:border-[#567C8D]/20 edit-btn cursor-pointer"
                         data-t="${safeEncode(t)}">
                        <p class="text-lg text-[#1C2B3A] italic font-medium">"${t.text}"</p>
                        <div class="flex items-center gap-4 pt-4 border-t border-[#F5EFEB]">
                            <div class="w-10 h-10 rounded-full bg-[#1C2B3A] flex items-center justify-center text-xs font-bold text-white uppercase">${t.avatar || t.author.charAt(0)}</div>
                            <div>
                               <p class="text-sm font-bold text-[#1C2B3A]">${t.author}</p>
                               <p class="text-[9px] font-black text-[#567C8D] uppercase tracking-widest">${t.role}</p>
                            </div>
                        </div>
                    </div>
                `).join('');

            listContainer.classList.remove('opacity-0');
            if (spinner) spinner.classList.add('hidden');

            document.querySelectorAll('.edit-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const data = safeDecode((btn as HTMLElement).dataset.t || '{}');
                    openModal(data as any);
                });
            });
        } catch (e) {
            console.error('Error loading testimonials', e);
        }
    }

    function openModal(t: any = null) {
        testimonialForm.reset();

        if (t) {
            document.getElementById('modal-title')!.innerText = 'Editar Testimonio';
            (document.getElementById('testimonial-id') as HTMLInputElement).value = t.id;
            // El campo en el form usa name="content" pero el objeto mapeado tiene .text
            (document.getElementById('field-text') as HTMLTextAreaElement).value  = t.text   || '';
            (document.getElementById('field-author') as HTMLInputElement).value   = t.author || '';
            (document.getElementById('field-role') as HTMLInputElement).value     = t.role   || '';
            (document.getElementById('field-avatar') as HTMLInputElement).value   = t.avatar || '';
            if (deleteBtn) deleteBtn.classList.remove('hidden');
        } else {
            document.getElementById('modal-title')!.innerText = 'Nuevo Testimonio';
            (document.getElementById('testimonial-id') as HTMLInputElement).value = '';
            if (deleteBtn) deleteBtn.classList.add('hidden');
        }

        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
    }

    const closeModal = () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
    };

    addBtn?.addEventListener('click', () => openModal());
    closeBtn?.addEventListener('click', closeModal);

    testimonialForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const saveBtn = document.getElementById('save-testimonial-btn') as HTMLButtonElement;
        saveBtn.disabled = true;

        const formData = new FormData(testimonialForm);

        // ─── FIX: nombres de campo correctos ─────────────────────────────
        // La DB tiene columnas: name, role, content, image_url
        // El form ahora tiene name="name", name="role", name="content", name="image_url"
        const payload = {
            name:      formData.get('name'),       // autor
            content:   formData.get('content'),    // texto del testimonio
            role:      formData.get('role'),
            image_url: formData.get('image_url'),  // iniciales (ej: "RA")
        };

        const id = formData.get('id');

        try {
            const { error } = id
                ? await supabase.from('testimonials').update(payload).eq('id', id)
                : await supabase.from('testimonials').insert([payload]);

            if (error) throw error;
            closeModal();
            loadTestimonials();
        } catch (err: any) {
            alert('Error al guardar: ' + err.message);
        } finally {
            saveBtn.disabled = false;
        }
    });

    deleteBtn?.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este testimonio permanentemente?')) return;
        const id = (document.getElementById('testimonial-id') as HTMLInputElement).value;
        if (!id) return;
        const { error } = await supabase.from('testimonials').delete().eq('id', id);
        if (error) alert('Error al eliminar: ' + error.message);
        else { closeModal(); loadTestimonials(); }
    });

    loadTestimonials();
  }
</script>