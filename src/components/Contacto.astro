---
// Contacto.astro
import { getContactData, getServices, cleanWhatsAppNumber } from '../utils/data';
const contactData = await getContactData();
const allServices = await getServices();

const services = allServices.length > 0 
  ? allServices.map(s => s.title) 
  : [
    'Fotografía Inmobiliaria',
    'Video & Cinematografía',
    'Desarrollo Digital',
    'Consultoría de Marca',
    'Airbnb Luxe Box',
    'Estrategia de Marca Personal'
  ];

const waNumber = cleanWhatsAppNumber(contactData.phone);
const instagramUrl = contactData.social?.instagram || null;
const linkedinUrl = contactData.social?.linkedin || null;
---

<section id="contacto" class="py-24 md:py-40 bg-[#F5EFEB] selection:bg-[#1C2B3A] selection:text-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 text-[#1C2B3A]">
    
    <div class="mb-20 md:mb-28">
      <div class="reveal inline-flex items-center gap-4 mb-8">
        <div class="w-10 h-px bg-[#567C8D]"></div>
        <span class="text-xs font-black text-[#567C8D] tracking-[0.4em] uppercase">Hablemos</span>
      </div>
      <h2 class="reveal reveal-delay-1 font-display text-5xl md:text-7xl xl:text-8xl font-bold leading-[1]">
        ¿Listo para <em class="text-[#567C8D] not-italic">trascender?</em>
      </h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4 reveal reveal-delay-1">
        <p class="text-xl md:text-2xl text-[#2F4156] font-medium leading-[1.6]">
          Transformo propiedades en activos digitales de alto valor. Cuéntame sobre tu proyecto.
        </p>
        <div class="w-2 h-2 rounded-full bg-[#567C8D] animate-pulse mt-8"></div>
        
        <div class="mt-12 space-y-4">
           {contactData.email && (
             <a href={`mailto:${contactData.email}`} class="channel-card group">
                <div class="channel-icon">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect width="22" height="16" x="1" y="4" rx="3"/><path d="m1 7 11 7 11-7"/></svg>
                </div>
                <div class="channel-info">
                  <span class="channel-tag">Email</span>
                  <p class="channel-value">{contactData.email}</p>
                </div>
             </a>
           )}
           <a href={`https://wa.me/${waNumber}`} target="_blank" class="channel-card group">
              <div class="channel-icon">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div class="channel-info">
                <span class="channel-tag">WhatsApp</span>
                <p class="channel-value">{contactData.phone}</p>
              </div>
           </a>
           {instagramUrl && (
             <a href={instagramUrl} target="_blank" class="channel-card group">
                <div class="channel-icon">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </div>
                <div class="channel-info">
                  <span class="channel-tag">Instagram</span>
                  <p class="channel-value">@anaiscontent</p>
                </div>
             </a>
           )}
           {linkedinUrl && (
             <a href={linkedinUrl} target="_blank" class="channel-card group">
                <div class="channel-icon">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.238 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </div>
                <div class="channel-info">
                  <span class="channel-tag">LinkedIn</span>
                  <p class="channel-value">Conectar</p>
                </div>
             </a>
           )}
        </div>
      </div>

      <div class="lg:col-span-8 reveal reveal-delay-2">
        <form id="contact-form" class="bg-[#1C2B3A] rounded-[40px] p-8 md:p-12 space-y-8 shadow-2xl">
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label for="nombre" class="text-[10px] font-black uppercase tracking-[0.2em] text-[#C8D9E6]/50">Nombre</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:border-[#567C8D] outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-[10px] font-black uppercase tracking-[0.2em] text-[#C8D9E6]/50">Email</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:border-[#567C8D] outline-none transition-all" />
            </div>
          </div>
          <div class="space-y-2">
            <label for="mensaje" class="text-[10px] font-black uppercase tracking-[0.2em] text-[#C8D9E6]/50">Mensaje</label>
            <textarea id="mensaje" name="mensaje" rows="4" required placeholder="¿Cómo puedo ayudarte?" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:border-[#567C8D] outline-none transition-all resize-none"></textarea>
          </div>
          <button type="submit" id="submit-btn" class="w-full bg-[#567C8D] hover:bg-[#C8D9E6] hover:text-[#1C2B3A] text-white font-black uppercase tracking-[0.2em] py-5 rounded-2xl transition-all active:scale-[0.98]">
            <span class="btn-text">Enviar Mensaje</span>
          </button>
          <div id="form-message" class="hidden p-6 rounded-2xl text-center text-xs font-bold uppercase tracking-widest"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .channel-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    padding: 24px;
    border-radius: 32px;
    text-decoration: none;
    border: 1px solid rgba(86, 124, 141, 0.1);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    z-index: 1;
  }
  .channel-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1C2B3A, #2F4156);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: -1;
  }
  .channel-card:hover { 
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 20px 40px rgba(28, 43, 58, 0.1);
    border-color: transparent;
  }
  .channel-card:hover::before { opacity: 1; }
  
  .channel-icon { 
    width: 56px; height: 56px; 
    display: flex; align-items: center; justify-content: center; 
    background: white; 
    border-radius: 20px; 
    color: #1C2B3A;
    box-shadow: 0 8px 16px rgba(0,0,0,0.05);
    transition: all 0.5s ease;
  }
  .channel-card:hover .channel-icon {
    background: rgba(255,255,255,0.1);
    color: white;
    transform: rotate(-5deg);
  }

  .channel-tag { 
    display: block; 
    font-size: 9px; 
    font-weight: 900; 
    text-transform: uppercase; 
    letter-spacing: 0.3em; 
    color: #567C8D; 
    margin-bottom: 4px;
    transition: color 0.5s ease;
  }
  .channel-card:hover .channel-tag { color: white; opacity: 0.7; }

  .channel-value { 
    font-size: 16px; 
    font-weight: 700; 
    color: #1C2B3A;
    transition: color 0.5s ease;
  }
</style>

<script>
  import { supabase } from '../lib/supabase';
  
  const initForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const msgDiv = document.getElementById('form-message');
    
    if (!form || !btn) return;

    form.onsubmit = async (e: SubmitEvent) => {
      e.preventDefault();
      btn.disabled = true;
      const btnText = btn.querySelector('.btn-text');
      if (btnText) btnText.textContent = 'Enviando...';
      
      const formData = new FormData(form);
      const payload = {
        name: formData.get('nombre'),
        email: formData.get('email'),
        message: formData.get('mensaje')
      };

      try {
        const { error } = await supabase.from('messages').insert([payload]);
        if (!error) {
          if (msgDiv) {
            msgDiv.textContent = '¡Tu mensaje ha sido enviado con éxito!';
            msgDiv.className = 'p-6 rounded-2xl text-center text-xs font-bold uppercase tracking-widest bg-emerald-500/10 text-emerald-500 block';
          }
          form.reset();
        } else throw error;
      } catch (err) {
        if (msgDiv) {
          msgDiv.textContent = 'Hubo un error al enviar. Por favor intenta por WhatsApp.';
          msgDiv.className = 'p-6 rounded-2xl text-center text-xs font-bold uppercase tracking-widest bg-red-500/10 text-red-500 block';
        }
      } finally {
        btn.disabled = false;
        if (btnText) btnText.textContent = 'Enviar Mensaje';
      }
    };
  };

  initForm();
  document.addEventListener('astro:page-load', initForm);
</script>
</script>