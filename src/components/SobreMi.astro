---
import { Image, getImage } from 'astro:assets';
import { getAboutData, getSiteData } from '../utils/data';
const aboutData = await getAboutData();
const siteData  = await getSiteData();

const imagesAbout = import.meta.glob<{ default: ImageMetadata }>('../assets/about/**/*.{jpeg,jpg,png,webp,svg,JPG,JPEG,PNG,WEBP,SVG}', { eager: true });

const rawGallery     = (aboutData.gallery || []).slice(0, 15);
const filteredGallery = rawGallery.map(url => {
  if (!url) return null;
  if (url.startsWith('http')) return { asset: url, optimizedSrc: url };
  const nPath = url.replace(/^\.\.\/\.\.\//, '../').replace(/^\.\.\//, '../');
  const key   = Object.keys(imagesAbout).find(k => k.toLowerCase().includes(nPath.toLowerCase()));
  const asset = key ? imagesAbout[key].default : null;
  return asset ? { asset, optimizedSrc: asset.src } : null;
}).filter(Boolean);

const hasPhotos    = filteredGallery.length > 0;
const displayItems = hasPhotos ? filteredGallery : [null, null, null, null];
---

<section id="sobre-mi" class="py-12 md:py-20 bg-white overflow-hidden selection:bg-[#2F4156] selection:text-white">
  
  <!-- ── PHOTO SLIDER ── -->
  <div class="mb-12 md:mb-16 relative overflow-x-auto md:overflow-hidden hide-scrollbar" id="slider-container">
    <div class="flex items-center gap-4 w-max slider-track" id="photo-slider">
      {[...displayItems, ...displayItems, ...displayItems].map((img, i) => (
        <div class={`flex-shrink-0 w-[80vw] md:w-[450px] aspect-[14/10] md:aspect-[16/10] rounded-[32px] md:rounded-[48px] overflow-hidden shadow-xl group relative transition-all duration-500 hover:shadow-2xl hover:scale-[1.02]
                    ${!img ? 'bg-[#1C2B3A] flex items-center justify-center border border-[#C8D9E6]/20' : 'cursor-pointer about-photo-card'}`}>
          {img ? (
            typeof img.asset === 'string' ? (
              <img 
                src={img.asset} 
                alt={`Trayectoria ${i + 1}`} 
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
                data-full-src={img.optimizedSrc}
                loading="lazy"
              />
            ) : (
              <Image 
                src={img.asset} 
                alt={`Trayectoria ${i + 1}`} 
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
                data-full-src={img.optimizedSrc}
                format="webp"
                quality={80}
                loading="lazy"
              />
            )
          ) : (
            <div class="flex flex-col items-center gap-4">
              <span class="text-[#C8D9E6]/30 font-display text-4xl italic font-black">{siteData.brandName}</span>
              <p class="text-[#C8D9E6]/20 text-[10px] uppercase tracking-widest font-bold">Sin imagen</p>
            </div>
          )}
          {img && (
            <>
              <div class="absolute inset-0 bg-[#1C2B3A]/10 group-hover:bg-transparent transition-colors duration-500"></div>
              <div class="absolute bottom-6 right-6 md:bottom-10 md:right-10 w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
              </div>
            </>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      <div class="lg:col-span-12 xl:col-span-7">
        <div class="reveal inline-flex items-center gap-3 mb-8 text-center md:text-left">
          <div class="w-10 h-px bg-[#567C8D]"></div>
          <span class="text-[11px] font-black text-[#567C8D] tracking-[0.35em] uppercase">Trayectoria & Visión</span>
        </div>
        <h2 class="reveal reveal-delay-1 font-display text-4xl md:text-7xl xl:text-[5.5rem] font-bold text-[#1C2B3A] leading-[1] mb-12">
          {aboutData.mainTitle}
        </h2>
      </div>
      <div class="lg:col-span-12 xl:col-span-5 reveal reveal-delay-2 lg:pl-12 lg:border-l-4 lg:border-[#567C8D] flex flex-col justify-center">
        <p class="text-xl md:text-2xl text-[#2F4156] font-medium leading-[1.6] mb-8">
          {aboutData.description}
        </p>
        <div class="flex items-center gap-4 text-[#567C8D] font-bold text-xs uppercase tracking-widest">
          <div class="w-2 h-2 rounded-full bg-[#567C8D] animate-pulse"></div>
          {aboutData.experience}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── LIGHTBOX ── -->
<div id="about-lightbox" class="fixed inset-0 z-[1000] flex items-center justify-center bg-[#1C2B3A] opacity-0 pointer-events-none transition-all duration-500 overflow-hidden" aria-modal="true" role="dialog">
  <div class="absolute inset-0 bg-[#1C2B3A]/95 backdrop-blur-3xl"></div>
  
  <button id="close-about-lightbox" class="absolute top-6 right-6 md:top-10 md:right-20 text-white p-4 md:p-5 bg-white/10 rounded-full hover:bg-white/20 transition-all z-[1030] backdrop-blur-md border border-white/10 active:scale-90">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>

  <div class="relative w-full h-full flex items-center justify-center p-4 md:p-12 z-[1010] pointer-events-none" id="about-lb-content">
    <img id="lightbox-img" src="" alt="Vista previa ampliada"
      style="max-width:100%;max-height:85vh;width:auto;height:auto;object-fit:contain;box-shadow:0 30px 60px rgba(0,0,0,0.9);border-radius:2px;transition:opacity 0.25s ease,transform 0.25s ease;opacity:0;transform:translateY(12px);pointer-events:auto;" />
  </div>
</div>

<style>
  /* ── Desktop: CSS marquee animation ── */
  @media (min-width: 768px) {
    @keyframes marquee-slow {
      0%   { transform: translate3d(0, 0, 0); }
      100% { transform: translate3d(-33.33%, 0, 0); }
    }
    .slider-track {
      animation: marquee-slow 60s linear infinite;
      will-change: transform;
    }
    .slider-track:hover {
      animation-play-state: paused;
    }
  }

  /* ── Mobile: no animation — let the user scroll naturally ── */
  @media (max-width: 767px) {
    .slider-track {
      animation: none !important;
    }
    #slider-container {
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
    }
    .about-photo-card,
    #photo-slider > div {
      scroll-snap-align: start;
    }
  }

  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .about-photo-card { will-change: transform; user-select: none; }
</style>

<script is:inline>
(function () {
  let lbKeyFn = null;

  const openLb = (src) => {
    const lb  = document.getElementById('about-lightbox');
    const img = document.getElementById('lightbox-img');
    if (!lb || !img) return;

    // Reset first so transition fires even for the same src
    img.style.opacity   = '0';
    img.style.transform = 'translateY(12px)';
    img.src = '';
    img.onload = null;

    lb.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';

    const show = () => {
      img.style.opacity   = '1';
      img.style.transform = 'translateY(0)';
    };
    img.onload = show;
    img.src    = src;
    if (img.complete && img.naturalWidth) show();
  };

  const closeLb = () => {
    const lb  = document.getElementById('about-lightbox');
    const img = document.getElementById('lightbox-img');
    if (!lb) return;
    lb.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
    if (img) {
      img.style.opacity   = '0';
      img.style.transform = 'translateY(12px)';
      img.src = '';
      img.onload = null;
    }
  };

  const init = () => {
    const lb       = document.getElementById('about-lightbox');
    const closeBtn = document.getElementById('close-about-lightbox');
    const lbContent = document.getElementById('about-lb-content');
    if (!lb) return;

    // onclick = safe to re-assign; no duplicate listeners
    document.querySelectorAll('.about-photo-card').forEach(card => {
      card.onclick = () => {
        const img = card.querySelector('img');
        if (img && img.dataset.fullSrc) openLb(img.dataset.fullSrc);
      };
    });

    if (closeBtn) closeBtn.onclick = closeLb;
    if (lb)       lb.onclick       = (e) => {
      if (e.target === lb || e.target === lbContent) closeLb();
    };

    if (lbKeyFn) window.removeEventListener('keydown', lbKeyFn);
    lbKeyFn = (e) => {
      if (lb.classList.contains('pointer-events-none')) return;
      if (e.key === 'Escape') closeLb();
    };
    window.addEventListener('keydown', lbKeyFn);
  };

  init();
  document.addEventListener('astro:page-load',  init);
  document.addEventListener('astro:after-swap', init);
})();
</script>