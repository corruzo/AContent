---
// SocialProof.astro
import { Image } from 'astro:assets';
import { getPartners, getTestimonials, normalizeAssetPath } from '../utils/data';

const rawPartners = await getPartners();
const partnerAssets = import.meta.glob<{ default: any }>('../assets/partners/**/*.{svg,png,jpg,jpeg,webp,gif,SVG,PNG,JPG,JPEG,WEBP,GIF}', { eager: true });

const partners = rawPartners.map((p) => {
  if (p.logo && p.logo.startsWith('http')) {
    return { ...p, logoAsset: p.logo, isRemote: true };
  }
  const normPath = normalizeAssetPath(p.logo);
  const assetKey = Object.keys(partnerAssets).find(k => k.toLowerCase().includes(normPath.toLowerCase()));
  return { ...p, logoAsset: assetKey ? partnerAssets[assetKey].default : null, isRemote: false };
}).filter(p => p.logoAsset !== null);

const displayPartners = partners.length > 0 ? partners : [
    { name: 'Partner 1', logoAsset: null },
    { name: 'Partner 2', logoAsset: null },
];


const testimonials = await getTestimonials();

const defaultTestimonials = [
  { text: 'Anais transformó por completo nuestra presencia digital. Sus fotos no solo muestran la propiedad, cuentan una historia profesional.', author: 'Roberto A.', role: 'Director Comercial', avatar: 'RA' },
  { text: 'Eficiencia y una visión artística impecable. Es la socia estratégica que todo desarrollo de lujo necesita.', author: 'Lucia M.', role: 'Fidelity Marketing', avatar: 'LM' },
  { text: 'El retorno de inversión tras sus piezas de video fue inmediato. Profesionalismo de clase mundial.', author: 'Martín P.', role: 'Arquitecto', avatar: 'MP' },
];

const displayTestimonials = testimonials.length > 0 ? testimonials : defaultTestimonials;
---

<section class="py-24 md:py-32 bg-white overflow-hidden selection:bg-[#F5EFEB] selection:text-[#1C2B3A]">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">

    <div class="text-center mb-20">
      <div class="reveal inline-flex items-center gap-4 mb-6">
        <div class="w-10 h-px bg-[#567C8D]"></div>
        <span class="text-xs font-black text-[#567C8D] tracking-[0.3em] uppercase">Confianza & Alianzas</span>
        <div class="w-10 h-px bg-[#567C8D]"></div>
      </div>
      <h2 class="font-display text-4xl md:text-7xl font-bold leading-[1.1] max-w-4xl mx-auto text-[#1C2B3A]">
        Respaldada por <em class="text-[#567C8D] not-italic">los mejores</em>
      </h2>
    </div>

    <!-- ── INFINITE LOGO MARQUEE ── -->
    <div class="relative overflow-hidden mb-24 md:mb-32 py-10">
      <div class="absolute inset-y-0 left-0 w-20 md:w-32 bg-gradient-to-r from-white to-transparent z-10"></div>
      <div class="absolute inset-y-0 right-0 w-20 md:w-32 bg-gradient-to-l from-white to-transparent z-10"></div>
      
      <div class="flex items-center gap-8 md:gap-16 w-max animate-logo-scroll">
        {[...displayPartners, ...displayPartners, ...displayPartners, ...displayPartners].map((partner) => (
          <div class="logo-card group flex-shrink-0">
            {partner.isRemote ? (
              <img src={partner.logoAsset} alt={partner.name} class="w-full h-full object-contain grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 p-2" />
            ) : partner.logoAsset ? (
              <Image src={partner.logoAsset} alt={partner.name} class="w-full h-full object-contain grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" width={180} height={80} />
            ) : (
                <span class="text-[9px] font-black uppercase tracking-widest text-[#567C8D]/40">{partner.name}</span>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- ── TESTIMONIALS ── -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {displayTestimonials.map((t, i) => (
        <div class={`reveal reveal-delay-${i+1} bg-[#F5EFEB]/50 rounded-[40px] p-10 md:p-12 border border-[#C8D9E6]/20 hover:bg-[#1C2B3A] hover:text-white transition-all duration-500 group shadow-sm hover:shadow-2xl`}>
          <div class="mb-8 text-[#567C8D] group-hover:text-white/20">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017V14H15.017C13.3592 14 12.017 12.6578 12.017 11V7C12.017 5.34315 13.3592 4 15.017 4H19.017C20.6738 4 22.017 5.34315 22.017 7V16.4862C22.017 17.5843 21.616 18.6468 20.8959 19.4624L18.4287 22.2568C18.1718 22.5476 17.7262 22.5833 17.4262 22.3364L14.417 19.9572C14.1554 19.7503 14.008 19.435 14.017 19.1027L14.017 21ZM5.01692 21L5.01692 18C5.01692 16.8954 5.91235 16 7.01692 16H10.0169V14H6.01692C4.35906 14 3.01692 12.6578 3.01692 11V7C3.01692 5.34315 4.35906 4 6.01692 4H10.0169C11.6738 4 13.0169 5.34315 13.0169 7V16.4862C13.0169 17.5843 12.6159 18.6468 11.8958 19.4624L9.42861 22.2568C9.17173 22.5476 8.72607 22.5833 8.42611 22.3364L5.41689 19.9572C5.15528 19.7503 5.00782 19.435 5.01692 19.1027L5.01692 21Z"/></svg>
          </div>
          <p class="text-xl md:text-2xl text-[#1C2B3A] group-hover:text-white font-medium italic leading-relaxed mb-12">"{t.text}"</p>
          <div class="flex items-center gap-4 mt-auto border-t border-[#C8D9E6]/50 group-hover:border-white/10 pt-8">
            <div class="w-12 h-12 rounded-full bg-[#1C2B3A] group-hover:bg-white/10 flex items-center justify-center text-sm font-bold text-white shadow-lg">{t.avatar}</div>
            <div>
              <p class="font-bold text-[#1C2B3A] group-hover:text-white">{t.author}</p>
              <p class="text-[9px] font-black text-[#567C8D] group-hover:text-[#C8D9E6] uppercase tracking-widest">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes logo-scroll {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }
  .animate-logo-scroll { animation: logo-scroll 30s linear infinite; }
  .logo-card {
    width: 120px; height: 60px; padding: 12px;
    background: white; border: 1px solid rgba(198, 217, 230, 0.4); border-radius: 16px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: all 0.4s ease;
  }
  .logo-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.1); border-color: #567C8D; }
  @media (min-width: 768px) { .logo-card { width: 180px; height: 80px; } }
</style>
