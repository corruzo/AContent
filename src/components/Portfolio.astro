---
// Portfolio.astro
import { Image, getImage } from 'astro:assets';
import { getProjects, normalizeAssetPath } from '../utils/data';
import type { ProjectData } from '../types';

// Load content
const rawProjects = await getProjects();
const portfolioAssets = import.meta.glob<{ default: any }>('../assets/portfolio/**/*.{svg,png,jpg,jpeg,webp,gif,mp4,webm,SVG,PNG,JPG,JPEG,WEBP,GIF,MP4,WEBM}', { eager: true });

// Process projects with assets and galleries
const processedProjects = await Promise.all(rawProjects.map(async (p) => {
  // Check if main image is a remote URL
  const isRemoteMain = p.image && p.image.startsWith('http');
  let asset = null;
  let mainOptimizedSrc = p.image || '';

  if (p.image && !isRemoteMain) {
    const normPath = normalizeAssetPath(p.image);
    const assetKey = Object.keys(portfolioAssets).find(k => k.toLowerCase() === normPath.toLowerCase());
    asset = assetKey ? portfolioAssets[assetKey].default : null;
    
    if (asset) {
        const optimizedMain = await getImage({ src: asset, format: 'webp', width: 1600, quality: 80 });
        mainOptimizedSrc = optimizedMain.src;
    }
  }
  
  // Gallery images
  const galleryUrls = (p.gallery || []).map(imgPath => {
    if (!imgPath) return null;
    if (imgPath.startsWith('http')) return imgPath;
    
    const nPath = normalizeAssetPath(imgPath);
    const key = Object.keys(portfolioAssets).find(k => k.toLowerCase() === nPath.toLowerCase());
    return key ? portfolioAssets[key].default.src : null;
  }).filter(Boolean);

  let isWide = p.wide ?? false;
  if (asset && typeof asset === 'object' && asset.width) {
    if (p.wide === undefined || p.wide === null) {
       isWide = asset.width > asset.height;
    }
  }

  const projectTitle    = p.title    || 'Proyecto Sin Nombre';
  const projectLocation = p.location || 'Consultar Ubicación';
  const projectColor    = p.color    || '#1C2B3A';

  return {
    ...p,
    title:    projectTitle,
    location: projectLocation,
    color:    projectColor,
    image:    asset || p.image,
    isWide,
    mediaSrc: mainOptimizedSrc,
    gallery:  [mainOptimizedSrc, ...galleryUrls].filter((v, i, a) => v && a.indexOf(v) === i)
  };
}));
---

<section id="portfolio" class="py-20 md:py-32 bg-[#F5EFEB] selection:bg-[#2F4156] selection:text-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">

    <!-- ── HEADER ── -->
    <div class="flex flex-col md:flex-row items-center md:items-end justify-between gap-12 mb-20 text-center md:text-left">
      <div>
        <div class="reveal inline-flex items-center gap-3 mb-5">
          <div class="w-10 h-px bg-[#567C8D]"></div>
          <span class="text-[11px] font-black text-[#567C8D] tracking-[0.3em] uppercase">Visual Storytelling</span>
        </div>
        <h2 class="font-display text-5xl lg:text-7xl font-bold text-[#1C2B3A] leading-[1.05]">
          Portafolio de <br class="hidden lg:block"/><em class="text-[#567C8D] not-italic">Propiedades</em>
        </h2>
      </div>
    </div>

    <!-- ── GRID ── -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      {processedProjects.map((p, i) => (
        <div 
          data-reveal 
          data-gallery={JSON.stringify(p.gallery)}
          data-title={p.title}
          role="button"
          aria-label={`Ver galería de ${p.title}`}
          tabindex="0"
          class={`reveal portfolio-item group relative rounded-[40px] lg:rounded-[60px] overflow-hidden cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-700
                  ${p.isWide ? 'md:col-span-8 h-[400px] lg:h-[550px]' : 'md:col-span-4 h-[400px] lg:h-[550px]'}`}
          style={`background-color: ${p.color}`}
        >
          <div class={`absolute inset-0 w-full h-full overflow-hidden ${!p.image ? 'skeleton' : ''}`}>
            {p.image && (
              typeof p.image === 'string' ? (
                <img 
                  src={p.image} 
                  alt={p.title} 
                  class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-110"
                  loading="lazy"
                />
              ) : (
                <Image 
                  src={p.image} 
                  alt={p.title} 
                  class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-110"
                  format="webp"
                  quality={85}
                />
              )
            )}
          </div>

          <div class="absolute inset-0 bg-gradient-to-t from-[#1C2B3A] via-[#1C2B3A]/30 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-700"></div>
          
          <div class="absolute inset-0 p-8 lg:p-12 flex flex-col justify-end transform transition-transform duration-700 pointer-events-none">
            <div class="translate-y-0 lg:translate-y-4 lg:group-hover:translate-y-0 transition-transform duration-500">
              <span class="inline-block text-[9px] font-black uppercase tracking-[0.4em] text-[#C8D9E6] mb-3 opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity delay-100">Click para ver galería</span>
              <h3 class="font-display text-2xl lg:text-4xl font-bold text-white leading-tight mb-4">{p.title}</h3>
              <div class="flex items-center gap-4 border-t border-white/20 pt-4 overflow-hidden h-auto lg:h-0 lg:opacity-0 lg:group-hover:h-12 lg:group-hover:opacity-100 transition-all duration-500 uppercase tracking-widest text-[10px] text-white/70">
                {p.location}
              </div>
            </div>
          </div>
          <div class="absolute inset-0 z-30 cursor-pointer" aria-hidden="true"></div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- ── LIGHTBOX MODAL ── -->
<div id="portfolio-modal" class="fixed inset-0 z-[1000] flex items-center justify-center bg-[#1C2B3A] opacity-0 invisible pointer-events-none transition-all duration-500 overflow-hidden" aria-modal="true" role="dialog">
  
  <div class="absolute inset-0 bg-[#1C2B3A]/95 backdrop-blur-2xl"></div>

  <div class="absolute top-6 left-6 md:top-10 md:left-20 z-[1020] text-white">
    <span id="gallery-counter" class="text-[#C8D9E6] font-display text-2xl md:text-4xl font-black italic block mb-1 md:mb-2 text-shadow-lg">1 / 1</span>
    <h4 id="gallery-title" class="text-[10px] md:text-sm font-bold uppercase tracking-[0.3em] opacity-80">PROYECTO</h4>
  </div>

  <button id="modal-close" aria-label="Cerrar galería" class="absolute top-6 right-6 md:top-10 md:right-20 text-white hover:text-[#C8D9E6] transition-all bg-white/10 hover:bg-white/20 rounded-full p-4 md:p-5 z-[1030] backdrop-blur-md border border-white/10 active:scale-90 shadow-2xl">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <button id="prev-btn" class="absolute left-2 md:left-12 top-1/2 -translate-y-1/2 text-white/50 hover:text-white hover:scale-110 transition-all z-[1020] p-4 group">
    <svg class="w-8 h-8 md:w-12 md:h-12 group-active:scale-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button id="next-btn" class="absolute right-2 md:right-12 top-1/2 -translate-y-1/2 text-white/50 hover:text-white hover:scale-110 transition-all z-[1020] p-4 group">
    <svg class="w-8 h-8 md:w-12 md:h-12 group-active:scale-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
  </button>

  <div class="relative w-full h-full flex items-center justify-center p-4 md:p-12 z-[1010] pointer-events-none" id="modal-content-wrapper">
    <!-- Improved Brand Spinner -->
    <div id="modal-spinner" class="absolute inset-0 flex items-center justify-center opacity-0 invisible transition-all duration-300 z-[1050] pointer-events-none">
       <div class="flex flex-col items-center gap-6">
          <div class="relative">
            <div class="w-16 h-16 border-4 border-white/10 border-t-white rounded-full animate-spin"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-2 h-2 bg-white rounded-full animate-ping"></div>
            </div>
          </div>
          <div class="text-center">
            <span class="block text-[11px] font-black uppercase tracking-[0.5em] text-white animate-pulse mb-1">Anais Content</span>
            <span class="text-[8px] font-bold uppercase tracking-[0.3em] text-white/40">Cargando Galería...</span>
          </div>
       </div>
    </div>
    <!-- inline style handles transitions instead of Tailwind classes to avoid class-list conflicts -->
    <img id="modal-image" src="" alt="Vista previa de galería"
      style="max-width:100%;max-height:85vh;width:auto;height:auto;object-fit:contain;transition:opacity 0.25s ease,transform 0.25s ease;opacity:0;transform:translateX(12px);box-shadow:0 30px 60px rgba(0,0,0,0.9);border-radius:2px;pointer-events:auto;" />
  </div>
</div>

<script is:inline>
(function () {
  // ── Shared state (module-level so re-inits don't reset it) ──
  let gallery   = [];
  let idx       = 0;
  let title     = '';
  let keyFn     = null;   // reference to keyboard handler so we can replace it safely

  // ── Helpers ──────────────────────────────────────────────────
  const getEl = (id) => document.getElementById(id);

  const setImage = (newIdx) => {
    const img = getEl('modal-image');
    if (!img || !gallery.length) return;
    idx = (newIdx + gallery.length) % gallery.length;

    // Fade out
    img.style.opacity   = '0';
    img.style.transform = 'translateX(12px)';
    
    // Preload next
    const nextIdx = (idx + 1) % gallery.length;
    new Image().src = gallery[nextIdx];

    const counter = getEl('gallery-counter');
    const titleEl = getEl('gallery-title');
    if (counter) counter.textContent = `${idx + 1} / ${gallery.length}`;
    if (titleEl) titleEl.textContent  = title;

    // Show spinner ONLY if not cached
    const spinner = getEl('modal-spinner');
    const show = () => {
      img.style.opacity   = '1';
      img.style.transform = 'translateX(0)';
      if (spinner) spinner.classList.add('opacity-0', 'invisible');
    };

    img.onload  = show;
    img.onerror = () => { if (spinner) spinner.classList.add('opacity-0', 'invisible'); };
    
    img.src = gallery[idx];
    if (img.complete && img.naturalWidth) {
      show();
    } else {
      if (spinner) spinner.classList.remove('opacity-0', 'invisible');
    }
  };

  const openModal = (galleryJson, projectTitle) => {
    try {
      gallery = JSON.parse(galleryJson || '[]');
      title   = projectTitle || '';
      if (!gallery.length) return;
      const modal = getEl('portfolio-modal');
      if (!modal) return;
      modal.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
      document.body.style.overflow = 'hidden';
      setImage(0);
    } catch (e) { console.error('Gallery open error', e); }
  };

  const closeModal = () => {
    const modal = getEl('portfolio-modal');
    const img   = getEl('modal-image');
    if (!modal) return;
    modal.classList.add('opacity-0', 'pointer-events-none', 'invisible');
    document.body.style.overflow = '';
    // Reset image so the NEXT open always animates cleanly
    if (img) {
      img.style.opacity   = '0';
      img.style.transform = 'translateX(12px)';
      img.src = '';
      img.onload = null;
    }
  };

  // ── Wire up DOM (safe to call multiple times) ─────────────────
  const init = () => {
    const modal    = getEl('portfolio-modal');
    const closeBtn = getEl('modal-close');
    const prevBtn  = getEl('prev-btn');
    const nextBtn  = getEl('next-btn');
    if (!modal) return;

    // onclick assignment replaces any previous handler — no duplicates
    document.querySelectorAll('.portfolio-item').forEach(item => {
      item.onclick = () =>
        openModal(item.getAttribute('data-gallery'), item.getAttribute('data-title'));
    });

    if (closeBtn) closeBtn.onclick = (e) => { e.stopPropagation(); closeModal(); };
    if (prevBtn)  prevBtn.onclick  = (e) => { e.stopPropagation(); setImage(idx - 1); };
    if (nextBtn)  nextBtn.onclick  = (e) => { e.stopPropagation(); setImage(idx + 1); };

    modal.onclick = (e) => {
      if (e.target === modal || e.target.id === 'modal-content-wrapper') closeModal();
    };

    // Replace keyboard handler cleanly
    if (keyFn) window.removeEventListener('keydown', keyFn);
    keyFn = (e) => {
      if (modal.classList.contains('pointer-events-none')) return;
      if (e.key === 'Escape')     closeModal();
      if (e.key === 'ArrowRight') setImage(idx + 1);
      if (e.key === 'ArrowLeft')  setImage(idx - 1);
    };
    window.addEventListener('keydown', keyFn);
  };

  init();
  document.addEventListener('astro:page-load',  init);
  document.addEventListener('astro:after-swap', init);
})();
</script>

<style>
  .text-shadow-lg { text-shadow: 0 4px 12px rgba(0,0,0,0.5); }
</style>