---
// src/components/Servicios.astro
import { Image } from 'astro:assets';
import { 
    getServices, 
    getServicesConfig, 
    getBasenameFromPath,
    getFilenameFromPath 
} from '../utils/data';

const dynamicServices = await getServices();
const servicesConfig = await getServicesConfig();

const iconMap: Record<string, string> = {
  camera: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />`,
  video: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />`,
  drone: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 10a2 2 0 100 4 2 2 0 000-4z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 12L7 7m0 0a2 2 0 11-4-4 2 2 0 014 4zm10 0l-5 5m5-5a2 2 0 114-4 2 2 0 01-4 4zM7 17l5-5m-5 5a2 2 0 11-4 4 2 2 0 014-4zm10 0l-5-5m5 5a2 2 0 114 4 2 2 0 01-4-4z" />`,
  phone: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />`,
  home: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  branding: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
};

// Fallback services if none in CMS
const services = dynamicServices.length > 0 ? dynamicServices : [
  { icon: 'camera', title: 'Fotografía', subtitle: 'Estrategia Residencial', description: 'Capturamos la esencia de cada propiedad con ángulos que resaltan su valor único.', tag: 'Popular' },
  { icon: 'video', title: 'Video', subtitle: 'Producción de Proyectos', description: 'Narrativas cinematográficas que transmiten el estilo de vida de cada desarrollo.', tag: '' },
  { icon: 'drone', title: 'Drone', subtitle: 'Vistas 4K Certificadas', description: 'Perspectivas aéreas que ubican el proyecto en su entorno más privilegiado.', tag: '' },
];

// Load ALL images in services folder
const imagesBg = import.meta.glob<{ default: ImageMetadata }>('../assets/services/*.{jpeg,jpg,png,webp,svg,JPEG,JPG,PNG,WEBP,SVG}', { eager: true });

// Obtener los metadatos si encontramos una clave
const bgPath = servicesConfig.backgroundImage;
const bgAssetKey = bgPath ? Object.keys(imagesBg).find(k => k.toLowerCase().includes(bgPath.toLowerCase())) : null;
let bgMetadata = null;

if (bgAssetKey) {
    bgMetadata = imagesBg[bgAssetKey].default;
}

// Configuración de efectos
const bgOpacity = 0.1;        
const bgBlur = '0px';         
const bgColorOverlay = '#1C2B3A'; 
const bgOverlayOpacity = 0.9;  
---

<section id="servicios" class="py-24 md:py-40 relative overflow-hidden selection:bg-[#567C8D] selection:text-white min-h-[600px]">
  
  <!-- BACKGROUND LAYER -->
  <div class="absolute inset-0 z-0 overflow-hidden bg-[#1C2B3A]">
    {bgMetadata ? (
      <div class="w-full h-full skeleton">
        <Image 
          src={bgMetadata} 
          alt="Fondo decorativo" 
          class="w-full h-full object-cover transition-opacity duration-1000"
          style={{
            opacity: bgOpacity,
            filter: `blur(${bgBlur})`
          }}
          loading="lazy"
          quality={80}
        />
        <div class="absolute inset-0" style={{ backgroundColor: bgColorOverlay, opacity: bgOverlayOpacity }}></div>
      </div>
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-[#1C2B3A] to-[#2F4156]"></div>
    )}
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 relative z-20">
    <div class="mb-16 md:mb-32">
      <div class="reveal inline-flex items-center gap-4 mb-8">
        <div class="w-10 h-px bg-[#567C8D]"></div>
        <span class="text-xs font-black text-[#567C8D] tracking-[0.4em] uppercase">Especialidades</span>
      </div>
      <h2 class="reveal reveal-delay-1 font-display text-4xl md:text-7xl lg:text-[5.5rem] font-bold text-white leading-[1] max-w-4xl">
        Soluciones que elevan el valor <em class="text-[#567C8D] not-italic">de mercado</em>
      </h2>
    </div>

    <!-- ── SERVICES GRID (Optimized Spacing) ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map((s, i) => (
        <div
          class={`reveal reveal-delay-${(i % 3) + 1} 
                  group bg-white/95 backdrop-blur-md rounded-[40px] md:rounded-[48px]
                  p-8 md:p-10 lg:p-14 border border-white/20
                  hover:bg-white hover:border-[#567C8D]/50 transition-all duration-700
                  h-full flex flex-col shadow-2xl overflow-hidden`}
        >
          <div class="w-14 h-14 md:w-16 md:h-16 rounded-2xl bg-[#1C2B3A]/10 group-hover:bg-[#567C8D] flex items-center justify-center mb-8 md:mb-10 transition-all duration-500 border border-white/20 group-hover:scale-110">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-[#1C2B3A] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <Fragment set:html={iconMap[s.icon] || iconMap.camera} />
            </svg>
          </div>

          <div class="mt-auto">
            <div class="flex items-center gap-3 mb-3">
              <h3 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-[#1C2B3A] transition-colors">{s.title}</h3>
              {s.tag && (
                <span class="bg-[#567C8D] text-white text-[8px] font-black uppercase px-3 py-1.5 rounded-full tracking-widest shadow-lg shadow-[#567C8D]/20">{s.tag}</span>
              )}
            </div>
            <p class="text-[9px] md:text-[10px] font-black text-[#567C8D] uppercase tracking-[0.3em] mb-6 md:mb-8">{s.subtitle}</p>
            <p class="text-sm md:text-base lg:text-lg text-[#1C2B3A]/70 group-hover:text-[#1C2B3A] leading-relaxed transition-colors">{s.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>