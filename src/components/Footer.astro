---
// Footer.astro
import { getContactData, getSiteData, cleanWhatsAppNumber, getSiteLogo } from '../utils/data';
const contactData = await getContactData();
const siteData = await getSiteData();
const waNumber = cleanWhatsAppNumber(contactData.phone);
const siteLogo = await getSiteLogo();
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#sobre-mi', label: 'Trayectoria' },
  { href: '#servicios', label: 'Soluciones' },
  { href: '#portfolio', label: 'Visuales' },
  { href: '#contacto', label: 'Contacto' },
];
---

<footer class="bg-[#1C2B3A] border-t border-[#2F4156] py-12 md:py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    
    <!-- ── DESKTOP VIEW ── -->
    <div class="hidden md:grid grid-cols-3 gap-16 mb-16">
      <div>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 md:w-20 md:h-20 flex items-center justify-center drop-shadow-xl transition-transform hover:scale-105">
            {siteLogo ? (
              <img src={siteLogo} alt="Logo" class="w-full h-full object-contain brightness-0 invert" />
            ) : (
              <div class="w-full h-full bg-white/10 rounded-xl flex items-center justify-center font-display text-3xl text-white">
                {siteData.brandName.charAt(0)}
              </div>
            )}
          </div>
          <h3 class="font-display text-3xl font-bold text-white mt-4">{siteData.brandName}<span class="text-[#567C8D]">.</span></h3>
        </div>
        <p class="text-sm text-[#567C8D] font-medium leading-relaxed max-w-xs">
          {contactData.footerTagline || 'Estrategia visual para activos inmobiliarios de lujo.'}
        </p>
      </div>
      <div>
        <h4 class="text-xs font-bold text-[#567C8D] uppercase tracking-widest mb-6">Navegación</h4>
        <ul class="space-y-3 font-bold uppercase tracking-[0.14em] text-[10px]">
           {navLinks.map(link => (
             <li><a href={link.href} class="text-[#C8D9E6]/60 hover:text-white transition-all">{link.label}</a></li>
           ))}
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-bold text-[#567C8D] uppercase tracking-widest mb-6">Conectar</h4>
        <div class="flex gap-4">
           <!-- Instagram -->
           {contactData.social?.instagram && (
             <a href={contactData.social.instagram} target="_blank" class="w-10 h-10 rounded-xl bg-[#2F4156] flex items-center justify-center text-[#C8D9E6] hover:bg-white hover:text-[#2F4156] transition-all shadow-lg">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                 <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                 <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
                 <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
               </svg>
             </a>
           )}
            <!-- WhatsApp -->
            <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 rounded-xl bg-[#2F4156] flex items-center justify-center text-[#C8D9E6] hover:bg-white hover:text-[#2F4156] transition-all shadow-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                 <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path>
              </svg>
            </a>
            <!-- LinkedIn -->
            {contactData.social?.linkedin && (
              <a href={contactData.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-10 h-10 rounded-xl bg-[#2F4156] flex items-center justify-center text-[#C8D9E6] hover:bg-white hover:text-[#2F4156] transition-all shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </a>
            )}
        </div>
      </div>
    </div>

    <!-- ── MOBILE VIEW ── -->
    <div class="md:hidden flex flex-col gap-10 mb-12 text-center">
      <div class="flex flex-col items-center">
          <div class="w-16 h-16 md:w-20 md:h-20 flex items-center justify-center mb-4 drop-shadow-2xl">
            {siteLogo ? (
              <img src={siteLogo} alt="Logo" class="w-full h-full object-contain brightness-0 invert" />
            ) : (
              <div class="w-full h-full bg-white/10 rounded-xl flex items-center justify-center font-display text-4xl text-white">
                {siteData.brandName.charAt(0)}
              </div>
            )}
          </div>
         <p class="text-[11px] text-[#C8D9E6]/40 uppercase tracking-[0.2em] font-bold">Anais Cruz • Estratega Visual</p>
         <h3 class="font-display text-3xl font-bold text-white mt-4">{siteData.brandName}<span class="text-[#567C8D]">.</span></h3>
      </div>
      
      <div class="flex justify-center gap-6">
         {contactData.social?.instagram && (
           <a href={contactData.social.instagram} target="_blank" class="text-[#C8D9E6] hover:text-white transition-all">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
             </svg>
           </a>
         )}
         <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="text-[#C8D9E6] hover:text-white transition-all">
           <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path>
           </svg>
         </a>
         {contactData.social?.linkedin && (
           <a href={contactData.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-[#C8D9E6] hover:text-white transition-all">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
                <circle cx="4" cy="4" r="2"></circle>
             </svg>
           </a>
         )}
      </div>
    </div>

    <!-- ── FOOTER BOTTOM ── -->
    <div class="border-t border-white/5 pt-10 flex flex-col md:flex-row items-center justify-between gap-6 text-center">
      <div class="flex flex-col md:items-start gap-1">
        <p class="text-[9px] md:text-xs text-[#567C8D]/60 font-medium uppercase tracking-[0.1em]">© {currentYear} ANAIS CRUZ. ALL RIGHTS RESERVED.</p>
        <p class="text-[9px] md:text-xs text-[#567C8D]/60 font-medium uppercase tracking-[0.1em]">{contactData.address || 'COSTA RICA'} • REAL ESTATE STRATEGY</p>
      </div>
      
      <div class="h-8 w-px bg-white/5 hidden md:block"></div>

      <div class="flex flex-col md:items-end gap-1 group">
        <span class="text-[8px] text-[#567C8D]/40 uppercase tracking-widest font-black">Socio Tecnológico</span>
        <a href="https://www.instagram.com/vive.flow/" target="_blank" rel="noopener noreferrer" class="text-[10px] md:text-xs font-bold text-[#C8D9E6]/60 group-hover:text-white transition-all uppercase tracking-[0.22em]">
          Diseñado por <span class="text-white border-b border-[#C8D9E6]/30 group-hover:border-white transition-all">VIVE FLOW SYSTEM</span>
        </a>
      </div>
    </div>

  </div>
</footer>

